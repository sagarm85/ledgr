OLLAMA_MODEL=mistral
OLLAMA_HOST=http://localhost:11434
KAFKA_BROKER=localhost:9092
KAFKA_PARTITIONS=9
ES_HOST=http://localhost:9200
ES_INDEX_PREFIX=invoices
CH_HOST=localhost
CH_PORT=8123
CH_DB=reconciliation
PG_URL=postgresql://invoice_user:invoice_pass@localhost:5432/invoice_db
API_PORT=8000
JWT_SECRET=change-this-in-production
LOG_LEVEL=INFO
REACT_APP_OLLAMA_MODEL=mistral

# Demo mode — slows reconciliation so widgets animate visibly in the UI
# Set to 0 (or remove) for production full-speed processing
# Recommended demo values: 200 (fast), 500 (medium), 1000 (slow)
DEMO_SLEEP_MS=0
# Smaller batches = smoother widget updates during demo
RECONCILE_BATCH_SIZE=500
